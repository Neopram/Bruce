# =============================================================================
# Bruce AI - Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# --- API Configuration ---
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=False
LOG_LEVEL=info
SECRET_KEY=          # Generate: python -c "import secrets; print(secrets.token_hex(32))"
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:3000

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# --- Vector Database ---
VECTOR_DB_PATH=/app/vector_db/faiss.index

# --- JWT Authentication ---
JWT_SECRET_KEY=      # Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- AI Models ---
PRIMARY_MODEL=phi3
FALLBACK_MODELS=deepseek,tinyllama
MODEL_MODE=auto
PHI3_MODEL_PATH=./models/Phi-3-mini-4k-instruct
DEEPSEEK_MODEL_PATH=./models/deepseek-coder-1.3b-base
TINYLLAMA_MODEL_PATH=./models/Tinyllama
DEEPSEEK_API_URL=http://localhost:8000/deepseek-api
DEEPSEEK_API_KEY=

# --- Speech & Avatar ---
ENABLE_SPEECH=true
VOICE_ID=bruce-founder
LANGUAGE_DEFAULT=en
MULTILANGUAGE_SUPPORT=true
ENABLE_VIDEO_REPORTS=true
AVATAR_STYLE=realistic

# --- Trading ---
ENABLE_TRADING=true
TRADING_MODE=auto
SUPPORTED_EXCHANGES=binance,coinbase,kraken,okx,uniswap,raydium,serum,jupiter
SNIPING_ENGINE=sniper_solana_ultra
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
ENABLE_SNIPING=true
SLIPPAGE_TOLERANCE=0.5
MEV_PROTECTION_ENABLED=true

# --- Arbitrage ---
ENABLE_ARBITRAGE=true
ARBITRAGE_MODES=triangular,sintetico,temporal,espacial
DARKPOOL_ACCESS_ENABLED=true
DARKPOOL_NODES=hft_nexus,blackhole_liquidity

# --- Freight Engine ---
ENABLE_FREIGHT_ENGINE=true
FREIGHT_API_KEY=
OIL_MONITORING_ENABLED=true
GEOINTELLIGENCE_MODELS=enabled
AIS_TRACKING_ENABLED=true

# --- External API Keys ---
MARKET_DATA_API_KEY=
CRYPTO_EXCHANGE_KEY=
AI_SENTIMENT_KEY=

# --- Storage ---
TEMP_FILE_DIR=/tmp/bruce-models
UPLOAD_DIR=/app/uploads
MAX_MEMORY_USAGE=8GB
ALLOW_LARGE_MODEL_LOADING=true

# --- Logging & Monitoring ---
LOGGING_LEVEL=info
LOG_FILE_PATH=/var/log/bruce.log
LOG_ROTATION_SIZE=10MB
LOG_RETENTION_DAYS=30
MONITORING_ENABLED=true
PROMETHEUS_EXPORTER=true

# --- Admin & Security ---
ADMIN_PASSWORD=      # Set a strong password
ALLOWED_ADMIN_IPS=127.0.0.1
ALLOW_CODE_REWRITING=true
ENCRYPTION_KEY=      # Generate: python -c "import secrets; print(secrets.token_hex(32))"
SALT_SECRET=         # Generate: python -c "import secrets; print(secrets.token_hex(16))"
ENVIRONMENT=production

# --- Self-Evolution ---
ENABLE_SELF_REFLECTION=true
ENABLE_META_AGENTS=true
AUTO_REFACTOR=true
AGENT_EXECUTOR_MODE=parallel

# --- WebSocket ---
WS_HOST=localhost
WS_PORT=3001
REALTIME_MARKET_FEED=true
REALTIME_LOG_STREAM=true

# --- Backup ---
BACKUP_ENABLED=true
BACKUP_LOCATION=/app/backups
DATABASE_BACKUP_ENABLED=true
DATABASE_BACKUP_PATH=/app/db_backups
BACKUP_INTERVAL=24h

# --- Experimental Features ---
NEURALINK_SIMULATION=true
TIMEFOLDING_ENGINE=true
HOLOGRAPHIC_TERMINAL=true
AVATAR_PHYSICALIZATION=true
UNIVERSE_MIRROR_TRADING=true

# --- Exchange API Keys ---
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

# --- Database ---
DATABASE_URL=postgresql://bruce:bruce_password@postgres:5432/bruce_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
